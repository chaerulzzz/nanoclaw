

# Added by skill
ASSISTANT_HAS_OWN_NUMBER=

# Default agent model (optional). Defaults to claude-sonnet-4-6.
# Set to claude-haiku-4-5-20251001 for faster/cheaper responses globally.
# You can also use !fast prefix in WhatsApp per-message to force Haiku.
AGENT_MODEL=

# DeepSeek fallback (optional) — used when Claude hits rate limits (429/503)
# Get your key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=
